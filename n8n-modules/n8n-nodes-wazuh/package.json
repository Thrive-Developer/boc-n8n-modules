{
	"name": "@beyond-ordinary-cloud/n8n-nodes-wazuh",
	"version": "0.1.6",
	"description": "n8n community node for Wazuh Server API and Wazuh Indexer API workflows",
	"license": "MIT",
	"homepage": "https://github.com/Thrive-Developer/boc/tree/main/n8n-modules/n8n-nodes-wazuh",
	"keywords": [
		"n8n-community-node-package"
	],
	"author": {
		"name": "devthrive",
		"email": "developer@thrive.co.id"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Thrive-Developer/boc.git",
		"directory": "n8n-modules/n8n-nodes-wazuh"
	},
	"scripts": {
		"build": "n8n-node build",
		"build:watch": "tsc --watch",
		"dev": "n8n-node dev",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"release": "n8n-node release",
		"prepublishOnly": "n8n-node prerelease",
		"test": "npm run build && node --test test/*.test.js"
	},
	"files": [
		"dist/credentials/WazuhIndexerApi.credentials.d.ts",
		"dist/credentials/WazuhIndexerApi.credentials.js",
		"dist/credentials/WazuhIndexerApi.credentials.js.map",
		"dist/credentials/WazuhManagerApi.credentials.d.ts",
		"dist/credentials/WazuhManagerApi.credentials.js",
		"dist/credentials/WazuhManagerApi.credentials.js.map",
		"dist/icons/boc.svg",
		"dist/nodes/WazuhManager"
	],
	"publishConfig": {
		"access": "public"
	},
	"n8n": {
		"n8nNodesApiVersion": 1,
		"strict": true,
		"credentials": [
			"dist/credentials/WazuhIndexerApi.credentials.js",
			"dist/credentials/WazuhManagerApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/WazuhManager/WazuhManager.node.js"
		]
	},
	"devDependencies": {
		"@n8n/node-cli": "*",
		"eslint": "9.29.0",
		"prettier": "3.9.4",
		"release-it": "20.2.1",
		"typescript": "5.9.3"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	}
}
